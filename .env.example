# Gemini API Key (Required for LLM/Gemini connection)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Tavily API Key (Required for web search agent tools)
# Get a free key from: https://tavily.com/
TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# Financial Modeling Prep API Key (Required for stock and market data)
# Get a free key from: https://site.financialmodelingprep.com/developer/docs/
FMP_API_KEY=YOUR_FMP_API_KEY

# Alpha Vantage API Key (Optional Fallback for stock and market data)
# Get a free key from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY

# Gemini Model Override (Defaults to gemini-2.5-flash if not specified)
# For local testing, we override to gemini-3.1-flash-lite due to key quota availability
GEMINI_MODEL=gemini-2.5-flash

# Exa AI API Key (Required for semantic/neural web search)
EXA_API_KEY=YOUR_EXA_API_KEY
